# ============================================================
# Langfuse Self-Hosted — Atlax360
# Copia este fichero a .env y rellena los valores
# cp env.example .env
# NUNCA commitear .env con secretos reales
# ============================================================

# --- Postgres ---
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO
POSTGRES_DB=langfuse

# --- ClickHouse ---
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO

# --- Redis ---
REDIS_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO

# --- MinIO (blob storage) ---
MINIO_ROOT_USER=langfuse
MINIO_ROOT_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO_MIN12CHARS

# --- Langfuse App ---
# URL pública donde se accede al dashboard (sin trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=GENERA_CON_openssl_rand_base64_32

# Genera con: openssl rand -base64 32
SALT=GENERA_CON_openssl_rand_base64_32

# Genera con: openssl rand -hex 32  (debe ser exactamente 64 chars hex)
ENCRYPTION_KEY=GENERA_CON_openssl_rand_hex_32

# --- Inicialización automática (primer arranque) ---
LANGFUSE_INIT_ORG_NAME=Atlax360
LANGFUSE_INIT_ORG_ID=atlax360
LANGFUSE_INIT_PROJECT_NAME=claude-code

# Admin inicial — cambia tras primer login
LANGFUSE_INIT_USER_EMAIL=jgcalvo@atlax360.com
LANGFUSE_INIT_USER_PASSWORD=CAMBIA_EN_PRIMER_LOGIN
LANGFUSE_INIT_USER_NAME=Joserra

# Claves del proyecto (se generan en el panel tras crear el proyecto)
# Rellena después del primer arranque y reinicia
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-PENDIENTE
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-PENDIENTE

# ============================================================
# LiteLLM Gateway — Fase 1 (opt-in, profile "litellm")
# Solo requeridas si se arranca con: docker compose --profile litellm up -d
# ============================================================

# Credencial corporativa Anthropic usada por el gateway para llamar a la API.
# Distinta del OAuth seat de los 38 devs — ese flujo NO pasa por LiteLLM.
ANTHROPIC_API_KEY=sk-ant-PENDIENTE

# Master key de LiteLLM — gates admin UI + creación de virtual keys (M3).
# Formato libre con prefijo "sk-". Genera con: echo sk-$(openssl rand -hex 32)
LITELLM_MASTER_KEY=sk-PENDIENTE

# Salt key — cifra las virtual keys persistidas en la BD "litellm".
# CRÍTICO: no cambiar tras emitir claves (invalida todas). Genera con: openssl rand -hex 32
LITELLM_SALT_KEY=GENERA_CON_openssl_rand_hex_32

# Admin UI (http://localhost:4001/ui) — login con estas credenciales
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=CAMBIA_EN_PRIMER_LOGIN

# --- LiteLLM M2: Langfuse callback ---
# El gateway envía un trace a Langfuse por cada llamada a la API.
# No requiere variables nuevas: docker-compose.yml mapea automáticamente
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY → LANGFUSE_PUBLIC_KEY (SDK LiteLLM)
# LANGFUSE_INIT_PROJECT_SECRET_KEY → LANGFUSE_SECRET_KEY
# LANGFUSE_HOST es hardcoded en compose: http://langfuse-web:3000
# ⚠ Asegúrate de que LANGFUSE_INIT_PROJECT_*_KEY estén rellenadas antes
# de arrancar con --profile litellm (no pueden ser "PENDIENTE").

# ============================================================
# LiteLLM Gateway — M3: virtual keys per-workload
# ============================================================

# Webhook para alertas de budget (opcional, formato Slack-compatible).
# LiteLLM dispara POST a esta URL cuando el spend de una key supera soft_budget.
# Sin configurar: warnings van a stdout (docker compose logs litellm).
# Genera URL en: https://api.slack.com/messaging/webhooks
# También compatible con n8n, Make, cualquier endpoint HTTP POST Slack-compatible.
LITELLM_ALERT_WEBHOOK_URL=

# Las virtual keys se generan con el script de provisioning (idempotente):
#   bun run scripts/provision-keys.ts
# Las claves se guardan en ~/.atlax-ai/virtual-keys.json (fuera del repo).
#
# Preview sin crear keys:
#   DRY_RUN=1 bun run scripts/provision-keys.ts
#
# Rotación de claves (ante compromiso de seguridad):
#   1. curl -X POST http://localhost:4001/key/delete -H "Authorization: Bearer $LITELLM_MASTER_KEY" \
#        -d '{"keys":["sk-old-key"]}'
#   2. bun run scripts/provision-keys.ts   # crea nueva key con mismo alias
#
# ADVERTENCIA: LITELLM_SALT_KEY es inmutable tras emitir claves.
# Cambiarla invalida TODAS las virtual keys en la BD.
